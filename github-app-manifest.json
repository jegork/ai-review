{
  "name": "rusty-bot",
  "description": "AI-powered pull request reviewer",
  "url": "https://github.com/your-org/rusty-bot",
  "hook_attributes": {
    "url": "https://your-rusty-bot-host/webhook"
  },
  "redirect_url": "https://your-rusty-bot-host/github/callback",
  "public": false,
  "default_permissions": {
    "pull_requests": "write",
    "issues": "read",
    "contents": "read"
  },
  "default_events": [
    "pull_request"
  ]
}
