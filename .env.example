# LLM Configuration
RUSTY_LLM_MODEL=anthropic/claude-sonnet-4-20250514
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Storage
RUSTY_DB_URL=file:./rusty.db

# GitHub App
GITHUB_APP_ID=
# inline PEM — use this or GITHUB_PRIVATE_KEY_PATH, not both
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Review behaviour (github server + azure-devops pipeline)
RUSTY_MODE=
RUSTY_REVIEW_STYLE=balanced
RUSTY_FOCUS_AREAS=
RUSTY_IGNORE_PATTERNS=
RUSTY_CUSTOM_INSTRUCTIONS=
RUSTY_FAIL_ON_CRITICAL=true

# Jira (optional)
RUSTY_JIRA_BASE_URL=
RUSTY_JIRA_EMAIL=
RUSTY_JIRA_API_TOKEN=

# Linear (optional)
RUSTY_LINEAR_API_KEY=

# Azure DevOps (optional, for server mode — pipeline mode uses SYSTEM_ACCESSTOKEN)
RUSTY_ADO_PAT=

# MCP Servers (optional) — JSON array of server configs
# Each entry needs: name, transport ("stdio"|"sse"|"streamable-http"), and transport-specific fields.
# Examples:
# RUSTY_MCP_SERVERS='[{"name":"docs","transport":"stdio","command":"npx","args":["-y","@my/mcp-docs-server"]},{"name":"sentry","transport":"sse","url":"https://mcp.sentry.io/sse"}]'
RUSTY_MCP_SERVERS=
